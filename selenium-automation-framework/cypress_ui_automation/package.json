{
  "name": "cypress_ui_automation_framework",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx cypress run",
    "test:headed": "npx cypress run --headed",
    "test:open": "npx cypress open",
    "test:debug": "npx cypress open --browser chrome",
    "report": "npx cypress run --reporter mochawesome"
  },
  "devDependencies": {
    "cypress": "^13.6.0",
    "dotenv": "^16.0.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
